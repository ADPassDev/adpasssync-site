{
  "name": "adpasssync-site",
  "version": "0.1.0",
  "private": true,
  "description": "ADPassSync marketing site and customer portal Worker",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:apply:local": "wrangler d1 execute adpasssync-db --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute adpasssync-db --remote --file=./schema.sql",
    "keys:generate": "node --experimental-strip-types scripts/generate-keys.ts"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.86.0"
  }
}
